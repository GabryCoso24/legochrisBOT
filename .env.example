# Discord bot token (required)
TOKEN=your_discord_bot_token

# OpenAI API key (required by ai.py)
OPENAI_API_KEY=your_openai_api_key

# ElevenLabs API key (optional; if missing, Edge-TTS fallback is used)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Edge-TTS voice (optional)
# Default: it-IT-GiuseppeMultilingualNeural
EDGE_TTS_VOICE=it-IT-GiuseppeMultilingualNeural
